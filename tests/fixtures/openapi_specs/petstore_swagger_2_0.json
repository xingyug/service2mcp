{
  "swagger": "2.0",
  "info": {
    "title": "Petstore Swagger",
    "version": "1.0.0"
  },
  "host": "petstore.swagger.io",
  "basePath": "/v2",
  "schemes": ["https"],
  "paths": {
    "/pets": {
      "get": {
        "operationId": "listPets",
        "summary": "List pets",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "type": "integer",
            "required": false
          }
        ],
        "responses": {
          "200": { "description": "OK" }
        }
      },
      "post": {
        "operationId": "createPet",
        "summary": "Create a pet",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "name": { "type": "string" }
              }
            }
          }
        ],
        "responses": {
          "201": { "description": "Created" }
        }
      }
    }
  },
  "securityDefinitions": {
    "api_key": {
      "type": "apiKey",
      "name": "api_key",
      "in": "header"
    }
  }
}
