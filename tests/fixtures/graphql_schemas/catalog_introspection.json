                  "defaultValue": null,
                  "type": {
                    "kind": "NON_NULL",
                    "name": null,
                    "ofType": {
                      "kind": "SCALAR",
                      "name": "ID",
                      "ofType": null
                    }
                  }
                },
                {
                  "name": "delta",
                  "description": "Inventory change amount.",
                  "defaultValue": null,
                  "type": {
                    "kind": "NON_NULL",
