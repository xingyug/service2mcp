                  }
                },
                {
                  "name": "reason",
                  "description": "Why the inventory changed.",
                  "defaultValue": null,
                  "type": {
                    "kind": "ENUM",
                    "name": "AdjustmentReason",
                    "ofType": null
                  }
                }
              ],
              "type": {
                "kind": "OBJECT",
                "name": "InventoryResult",
                "ofType": null
              }
            }
          ]
        },
        {
          "kind": "ENUM",
