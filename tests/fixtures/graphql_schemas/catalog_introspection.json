                  "defaultValue": null,
                  "type": {
                    "kind": "NON_NULL",
                    "name": null,
                    "ofType": {
                      "kind": "SCALAR",
                      "name": "String",
                      "ofType": null
                    }
                  }
                },
                {
                  "name": "category",
                  "description": "Product category filter.",
                  "defaultValue": null,
                  "type": {
                    "kind": "ENUM",
                    "name": "Category",
                    "ofType": null
                  }
                },
                {
                  "name": "filter",
                  "description": "Nested filter input.",
                  "defaultValue": null,
                  "type": {
                    "kind": "INPUT_OBJECT",
                    "name": "ProductFilter",
                    "ofType": null
                  }
                },
                {
                  "name": "limit",
                  "description": "Page size limit.",
                  "defaultValue": "10",
                  "type": {
                    "kind": "SCALAR",
                    "name": "Int",
                    "ofType": null
                  }
                }
              ],
              "type": {
                "kind": "NON_NULL",
                "name": null,
                "ofType": {
                  "kind": "LIST",
                  "name": null,
                  "ofType": {
                    "kind": "NON_NULL",
                    "name": null,
                    "ofType": {
                      "kind": "OBJECT",
                      "name": "Product",
                      "ofType": null
                    }
                  }
                }
              }
            }
          ]
        },
        {
          "kind": "OBJECT",
          "name": "Mutation",
          "fields": [
            {
