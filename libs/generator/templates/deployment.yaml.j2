apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ deployment_name }}
  namespace: {{ namespace }}
  labels:
{{ labels_yaml_4 }}
  annotations:
{{ annotations_yaml_4 }}
spec:
  replicas: {{ replicas }}
  selector:
    matchLabels:
{{ selector_labels_yaml_6 }}
  template:
    metadata:
      labels:
{{ labels_yaml_8 }}
      annotations:
{{ annotations_yaml_8 }}
    spec:
      automountServiceAccountToken: false
{% if image_pull_secrets %}
      imagePullSecrets:
{% for secret_name in image_pull_secrets %}
        - name: {{ secret_name }}
{% endfor %}
{% endif %}
{% if node_selector %}
      nodeSelector:
{% for key, value in node_selector.items() %}
        {{ key }}: {{ value }}
{% endfor %}
{% endif %}
      securityContext:
        runAsNonRoot: true
        runAsUser: 10001
        runAsGroup: 10001
        seccompProfile:
          type: RuntimeDefault
      containers:
        - name: runtime
          image: {{ runtime_image }}
          imagePullPolicy: {{ image_pull_policy }}
          env:
            - name: SERVICE_IR_PATH
              value: {{ service_ir_path }}
            - name: APP_PORT
              value: "{{ container_port }}"
            - name: TMPDIR
              value: /tmp
            - name: MCP_ALLOWED_HOSTS
              value: {{ mcp_allowed_hosts }}
{% if enable_native_grpc_unary %}
            - name: ENABLE_NATIVE_GRPC_UNARY
              value: "true"
{% endif %}
{% if enable_native_grpc_stream %}
            - name: ENABLE_NATIVE_GRPC_STREAM
              value: "true"
{% endif %}
{% for runtime_secret_env in runtime_secret_envs %}
            - name: {{ runtime_secret_env.env_name }}
              valueFrom:
                secretKeyRef:
                  name: {{ runtime_secret_env.secret_name }}
                  key: {{ runtime_secret_env.secret_key }}
{% endfor %}
          ports:
            - name: http
              containerPort: {{ container_port }}
              protocol: TCP
          livenessProbe:
            httpGet:
              path: /healthz
              port: http
          readinessProbe:
            httpGet:
              path: /readyz
              port: http
          securityContext:
            allowPrivilegeEscalation: false
            capabilities:
              drop:
                - ALL
            readOnlyRootFilesystem: true
          volumeMounts:
            - name: service-ir
              mountPath: /config
              readOnly: true
            - name: tmp
              mountPath: /tmp
      volumes:
        - name: service-ir
          configMap:
            name: {{ config_map_name }}
            items:
              - key: {{ service_ir_key }}
                path: {{ service_ir_key }}
        - name: tmp
          emptyDir:
            sizeLimit: 256Mi
