apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: {{ network_policy_name }}
  namespace: {{ namespace }}
  labels:
{{ labels_yaml_4 }}
  annotations:
{{ annotations_yaml_4 }}
spec:
  podSelector:
    matchLabels:
{{ selector_labels_yaml_6 }}
  policyTypes:
    - Egress
  egress:
    - to:
        - ipBlock:
            cidr: 0.0.0.0/0
      ports:
        - protocol: TCP
          port: {{ upstream_port }}
    - to:
        - ipBlock:
            cidr: 0.0.0.0/0
      ports:
        - protocol: UDP
          port: 53
        - protocol: TCP
          port: 53
