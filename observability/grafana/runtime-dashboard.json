{
  "id": null,
  "uid": "tool-compiler-runtime",
  "title": "Tool Compiler Runtime",
  "tags": ["tool-compiler", "runtime"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Tool Call QPS",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum by (operation_id, outcome) (rate(mcp_runtime_tool_calls_total[$__rate_interval]))",
          "legendFormat": "{{operation_id}} {{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Latency P95",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, operation_id) (rate(mcp_runtime_tool_latency_seconds_bucket[$__rate_interval])))",
          "legendFormat": "{{operation_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Upstream Error Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "sum by (operation_id, error_type) (rate(mcp_runtime_upstream_errors_total[$__rate_interval]))",
          "legendFormat": "{{operation_id}} {{error_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Circuit Breaker State",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "max by (operation_id) (mcp_runtime_circuit_breaker_state)",
          "legendFormat": "{{operation_id}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        }
      }
    }
  ]
}
