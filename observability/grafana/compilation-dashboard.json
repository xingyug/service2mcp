{
  "id": null,
  "uid": "tool-compiler-compilation",
  "title": "Tool Compiler Compilation",
  "tags": ["tool-compiler", "compilation"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Compilation Jobs By Status",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum by (status) (increase(compiler_workflow_jobs_total[$__range]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Stage Duration P95",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, stage) (rate(compiler_workflow_stage_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "{{stage}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Extractor Success Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "sum by (protocol) (rate(compiler_extractor_runs_total{outcome=\"success\"}[$__rate_interval])) / sum by (protocol) (rate(compiler_extractor_runs_total[$__rate_interval]))",
          "legendFormat": "{{protocol}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "LLM Token Usage",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "sum by (model, direction) (rate(compiler_llm_tokens_total[$__rate_interval]))",
          "legendFormat": "{{model}} {{direction}}",
          "refId": "A"
        }
      ]
    }
  ]
}
